{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/session-start.sh",
            "timeout": 10,
            "statusMessage": "Loading pending tasks..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/on-stop.sh",
            "timeout": 10,
            "statusMessage": "Checking active tasks..."
          }
        ]
      }
    ]
  }
}
