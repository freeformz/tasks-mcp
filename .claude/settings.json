{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|compact",
        "hooks": [
          {
            "type": "command",
            "command": "tasks-mcp hooks snapshot",
            "timeout": 10,
            "statusMessage": "Loading pending tasks..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "tasks-mcp hooks check-active",
            "timeout": 10,
            "statusMessage": "Checking active tasks..."
          }
        ]
      }
    ]
  }
}
